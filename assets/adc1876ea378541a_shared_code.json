ll px-4 py-3 rounded-lg border border-stone-200 bg-stone-50 focus:bg-white focus:border-[#E3C15E] focus:ring-1 focus:ring-[#E3C15E] outline-none transition-all text-sm text-stone-600\">\n                                    <option>Cosmetic Injectables</option>\n                                    <option>Facials &amp; Skincare</option>\n                                    <option>Laser Treatments</option>\n                                    <option>Body Wellness</option>\n                                    <option>General Consultation</option>\n                                </select>\n                            </div>\n                        </div>\n                        <div class=\"space-y-2\">\n                            <label for=\"message\" class=\"text-xs font-bold uppercase tracking-wide text-stone-600\">Message (Optional)</label>\n                            <textarea id=\"message\" rows=\"3\" class=\"w-full px-4 py-3 rounded-lg border border-stone-200 bg-stone-50 focus:bg-white focus:border-[#E3C15E] focus:ring-1 focus:ring-[#E3C15E] outline-none transition-all text-sm\"></textarea>\n                        </div>\n                        <div class=\"pt-4\">\n                            <button type=\"submit\" class=\"w-full py-4 bg-[#2C2C2C] text-white rounded-lg text-sm font-bold uppercase tracking-widest hover:bg-stone-800 transition-all shadow-lg hover:shadow-xl\">\n                                Send Request\n                            </button>\n                            <p class=\"text-[10px] text-center text-stone-400 mt-4\">\n                                * Note to dev: Connect to autoresponder.\n                            </p>\n                        </div>\n                    </form>\n                </div>\n\n                <!-- Info Side -->\n                <div class=\"lg:col-span-2 bg-[#D1DDE8]/40 p-8 lg:p-12 flex flex-col justify-center\">\n                    <h3 class=\"text-xl font-bold text-stone-900 mb-6\">Visit Us